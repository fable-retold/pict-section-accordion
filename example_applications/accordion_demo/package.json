{
	"name": "accordion_demo",
	"version": "0.0.1",
	"description": "Demo app showcasing pict-section-accordion (accordion / wizard / stepper over one step set).",
	"main": "source/Pict-Application-AccordionDemo.js",
	"scripts": {
		"start": "node source/Pict-Application-AccordionDemo.js",
		"build": "npx quack build && npx quack copy"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"dependencies": {
		"pict": "^1.0.373",
		"pict-application": "^1.0.34",
		"pict-view": "^1.0.68"
	},
	"devDependencies": {
		"quackage": "^1.3.0"
	},
	"copyFilesSettings": {
		"whenFileExists": "overwrite"
	},
	"copyFiles": [
		{ "from": "./html/*", "to": "./dist/" },
		{ "from": "./css/**", "to": "./dist/css/" },
		{ "from": "./node_modules/pict/dist/*", "to": "./dist/js/" }
	]
}
